###############################################################################
# MCP Stack — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
###############################################################################

# ── Logseq ──────────────────────────────────────────────────────────────────
# Generate from: Logseq → Settings → Features → HTTP API → Tokens
LOGSEQ_API_TOKEN=logseqbdBD1974
MCP_HTTP_AUTH_TOKEN=logseqbdBD1974
# Logseq runs on the host; host.docker.internal resolves to the host IP
LOGSEQ_API_URL=http://host.docker.internal:12315

# ── Firecrawl ────────────────────────────────────────────────────────────────
# Get a free API key at https://www.firecrawl.dev/app/api-keys
# For a fully self-hosted Firecrawl, also set FIRECRAWL_API_URL
FIRECRAWL_API_KEY=fc-your_firecrawl_api_key_here
# FIRECRAWL_API_URL=http://firecrawl-api:3002   # uncomment for self-hosted

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=elasticbdBD1974

# ── Mem0 ──────────────────────────────────────────────────────────────────────
# Choose ONE block below — LM Studio (local) OR OpenAI (cloud)

# ── Option A: LM Studio (fully local, no API key needed) ─────────────────────
# LM Studio must have:
#   1. A chat/completion model loaded   (e.g. Llama-3.2, Mistral, Qwen2.5)
#   2. An embedding model loaded        (e.g. nomic-embed-text, all-minilm)
# Find exact model identifiers in LM Studio → My Models tab or the server log.
#
# host.docker.internal resolves to your Windows host from inside Docker.
MEM0_LLM_PROVIDER=openai
MEM0_LLM_BASE_URL=http://host.docker.internal:1234/v1
MEM0_LLM_API_KEY=lm-studio
MEM0_LLM_MODEL=google/gemma-4-26b-a4b-qat

MEM0_EMBEDDER_PROVIDER=openai
MEM0_EMBEDDER_BASE_URL=http://host.docker.internal:1234/v1
MEM0_EMBEDDER_API_KEY=lm-studio
MEM0_EMBEDDER_MODEL=text-embedding-mxbai-embed-large-v1
# Set this to match your embedding model's output dimensions:
#   nomic-embed-text     → 768
#   all-minilm-l6-v2    → 384
#   all-minilm-l12-v2   → 384
#   bge-large-en-v1.5   → 1024
#   text-embedding-3-small (OpenAI) → 1536
MEM0_EMBEDDER_DIMS=1024

# ── Option B: OpenAI cloud (comment out Option A and uncomment this) ──────────
# OPENAI_API_KEY=sk-your_openai_key_here
# MEM0_LLM_PROVIDER=openai
# MEM0_LLM_MODEL=gpt-4o-mini
# MEM0_LLM_API_KEY=${OPENAI_API_KEY}
# MEM0_EMBEDDER_PROVIDER=openai
# MEM0_EMBEDDER_MODEL=text-embedding-3-small
# MEM0_EMBEDDER_API_KEY=${OPENAI_API_KEY}
# MEM0_EMBEDDER_DIMS=1536

# ── SearXNG ───────────────────────────────────────────────────────────────────
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
SEARXNG_SECRET=searxngbdBD1974
